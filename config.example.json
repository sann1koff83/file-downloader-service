{
  "server": {
    "host": "0.0.0.0",
    "port": 3000
  },
  "storage": {
    "targetFolder": "C:\\Temp\\downloads",
    "tempFolder": "C:\\FileDownloaderTemp"
  },
  "download": {
    "headersTimeoutMs": 5000,
    "bodyTimeoutMs": 45000,
    "concurrency": 10
  },
  "cleanup": {
    "cron": "0 * * * *",
    "olderThanHours": 24
  },
  "security": {
    "apiKey": "your-api-key-here"
  }
}